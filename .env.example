RUST_LOG=info

# Bind address for websocket relay
BIND_ADDR=0.0.0.0:8080

# Limits
WS_RATE_LIMIT=30
WS_WINDOW_SECS=5
HTTP_RATE_LIMIT=120
HTTP_WINDOW_SECS=60
MAX_WS_TEXT_LEN=1048576
MAX_ROOM_CONNECTIONS=200
MAX_ROOM_ID_LEN=128
WS_AUTH_SECRET=
WS_AUTH_ENFORCE=0

# Optional distributed rate limiting (Redis REST, e.g., Upstash)
RATE_LIMIT_REDIS_REST_URL=
RATE_LIMIT_REDIS_REST_TOKEN=
